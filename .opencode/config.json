{
  "mcpServers": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "auth": {
        "type": "bearer",
        "token": "${GITHUB_MCP_TOKEN}"
      }
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "auth": {
        "type": "oauth"
      }
    },
    "notion": {
      "type": "remote",
      "url": "https://api.notion.com/mcp",
      "auth": {
        "type": "bearer",
        "token": "${NOTION_TOKEN}"
      }
    }
  }
}
