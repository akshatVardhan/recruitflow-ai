# RecruitFlow AI - Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env - it is in .gitignore.
# Keep this file up to date whenever a new variable is added.

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/recruitflow
CLOUD_SQL_INSTANCE=                         # GCP Cloud SQL instance connection name

# -------------------------------------------------------------------
# Redis
# -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------------
# Qdrant
# -------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                             # leave empty for local, set for cloud

# -------------------------------------------------------------------
# MinIO / GCS File Storage
# -------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false                          # true in production

GCS_BUCKET_NAME=                            # production only
GCS_CREDENTIALS_JSON=                       # path to service account JSON, production only

# -------------------------------------------------------------------
# LLM - DeepSeek via LiteLLM
# -------------------------------------------------------------------
LITELLM_API_KEY=                            # DeepSeek API key
DEEPSEEK_API_KEY=                           # same as above, kept for reference

# -------------------------------------------------------------------
# External APIs
# -------------------------------------------------------------------
PROXYCURL_API_KEY=                          # Proxycurl for talent finder

# -------------------------------------------------------------------
# Auth
# -------------------------------------------------------------------
JWT_SECRET_KEY=                             # long random string, min 32 chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------------------------
# Monitoring
# -------------------------------------------------------------------
SENTRY_DSN_BACKEND=                         # Sentry DSN for FastAPI
CLOUD_RUN_URL=                              # production Cloud Run URL for keep-warm

# -------------------------------------------------------------------
# MCP Integrations (OpenCode agents)
# -------------------------------------------------------------------
GITHUB_MCP_TOKEN=                           # GitHub PAT, repo + PR + actions scopes
NOTION_TOKEN=                               # Notion integration token

# -------------------------------------------------------------------
# Frontend (prefix with NEXT_PUBLIC_ for client-side access)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=                     # Sentry DSN for Next.js