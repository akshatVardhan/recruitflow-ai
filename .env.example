# RecruitFlow AI - Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env - it is in .gitignore.
# Keep this file up to date whenever a new variable is added.

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/recruitflow
# Production (Cloud SQL): postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/INSTANCE_CONNECTION_NAME
CLOUD_SQL_INSTANCE=                         # GCP Cloud SQL instance connection name, e.g. project:region:instance

# -------------------------------------------------------------------
# Redis
# -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------------
# Qdrant
# -------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                             # leave empty for local, set for cloud

# -------------------------------------------------------------------
# MinIO / GCS File Storage
# -------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false                          # true in production

GCS_BUCKET_NAME=recruitflow-ai-documents    # production only
GCS_CREDENTIALS_JSON=                       # path to service account JSON, production only

# -------------------------------------------------------------------
# LLM - DeepSeek via LiteLLM
# -------------------------------------------------------------------
LITELLM_API_KEY=                            # DeepSeek API key
DEEPSEEK_API_KEY=                           # same as above, kept for reference

# -------------------------------------------------------------------
# External APIs
# -------------------------------------------------------------------
PROXYCURL_API_KEY=                          # Proxycurl for talent finder

# -------------------------------------------------------------------
# Auth
# -------------------------------------------------------------------
JWT_SECRET_KEY=                             # long random string, min 32 chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------------------------
# Monitoring
# -------------------------------------------------------------------
SENTRY_DSN_BACKEND=                         # Sentry DSN for FastAPI
CLOUD_RUN_URL=https://recruitflow-backend-424745949201.asia-south1.run.app  # production Cloud Run URL for keep-warm
GCP_PROJECT_ID=recruitflow-ai-500719        # GCP project ID
ARTIFACT_REGISTRY=asia-south1-docker.pkg.dev/recruitflow-ai-500719/recruitflow  # Artifact Registry for Docker images

# -------------------------------------------------------------------
# MCP Integrations (OpenCode agents)
# -------------------------------------------------------------------
GITHUB_MCP_TOKEN=                           # GitHub PAT, repo + PR + actions scopes

# -------------------------------------------------------------------
# Frontend (prefix with NEXT_PUBLIC_ for client-side access)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=                     # Sentry DSN for Next.js